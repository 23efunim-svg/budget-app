rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Семейные бюджеты: читать/писать может любой, кто знает ID документа.
    // ID — 12 символов из нашего алфавита с дефисами, подобрать нереально (10^18 комбинаций).
    // Жёсткий лимит: код валидного формата + размер state не больше ~1 МБ.
    match /households/{code} {
      allow read: if code.matches('^[A-HJ-NP-Z2-9]{4}-[A-HJ-NP-Z2-9]{4}-[A-HJ-NP-Z2-9]{4}$');
      allow create, update: if
        code.matches('^[A-HJ-NP-Z2-9]{4}-[A-HJ-NP-Z2-9]{4}-[A-HJ-NP-Z2-9]{4}$')
        && request.resource.data.keys().hasOnly(['state', 'updatedAt'])
        && request.resource.data.state is map
        && request.resource.size() < 900000;
      allow delete: if false;
    }
    // Всё остальное закрыто.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
